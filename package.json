{
  "name": "@biglone/session-bridge-plugin",
  "version": "0.1.0",
  "description": "Cross-provider session bridge plugin/CLI for Codex workflows",
  "type": "commonjs",
  "license": "MIT",
  "author": "Biglone",
  "homepage": "https://github.com/Biglone/session-bridge-plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/Biglone/session-bridge-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/Biglone/session-bridge-plugin/issues"
  },
  "keywords": [
    "codex",
    "plugin",
    "session",
    "resume",
    "bridge"
  ],
  "bin": {
    "session-bridge-plugin": "npm/bin.cjs",
    "codex-session-bridge": "npm/bin.cjs",
